{
  "name": "brapci",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node scripts/generate-env.mjs",
    "prebuild": "node scripts/generate-env.mjs",
    "prewatch": "node scripts/generate-env.mjs",
    "preserve:ssr:brapci": "node scripts/generate-env.mjs",
    "start": "ng serve",
    "build": "ng build",
    "build:web2": "ng build --configuration web2",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:brapci": "node dist/brapci/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/platform-server": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@angular/ssr": "^20.3.21",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express-session": "^1.18.2",
    "@types/leaflet": "^1.9.21",
    "bootstrap": "^5.3.8",
    "cookie-parser": "^1.4.7",
    "cytoscape": "^3.33.1",
    "cytoscape-fcose": "^2.2.0",
    "d3": "^7.9.0",
    "d3-cloud": "^1.2.9",
    "express": "^5.1.0",
    "express-session": "^1.19.0",
    "highcharts": "^12.5.0",
    "leaflet": "^1.9.4",
    "rxjs": "~7.8.0",
    "three": "^0.183.2",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.21",
    "@angular/cli": "^20.3.21",
    "@angular/compiler-cli": "^20.3.0",
    "@types/d3": "^7.4.3",
    "@types/express": "^5.0.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.17.19",
    "@types/three": "^0.183.1",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.2"
  }
